<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Gabriel Fortin Cara </title>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;700&family=Inter:wght@300;400;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-dark: #0b0c10;
            --panel-bg: rgba(31, 40, 51, 0.7);
            --neon-cyan: #66fcf1;
            --neon-dim: #45a29e;
            --text-main: #c5c6c7;
            --text-white: #ffffff;
            --border-radius: 4px;
        }

        body {
            background-color: var(--bg-dark);
            color: var(--text-main);
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 40px 20px;
            background-image: radial-gradient(circle at 50% 50%, #1a1a2e 0%, #0b0c10 100%);
        }

        .container {
            max-width: 900px;
            margin: 0 auto;
            display: grid;
            gap: 20px;
        }

        header {
            border-bottom: 2px solid var(--neon-dim);
            padding-bottom: 20px;
            margin-bottom: 20px;
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            flex-wrap: wrap;
        }

        h1 {
            font-family: 'JetBrains Mono', monospace;
            color: var(--neon-cyan);
            font-size: 2.2rem;
            margin: 0;
            text-shadow: 0 0 10px rgba(102, 252, 241, 0.2);
            letter-spacing: -1px;
        }

        .subtitle {
            color: var(--text-white);
            font-size: 1rem;
            margin-top: 5px;
            font-family: 'JetBrains Mono', monospace;
        }

        .contact-details {
            text-align: right;
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            color: var(--neon-dim);
            line-height: 1.5;
        }

        .contact-details a {
            color: var(--neon-dim);
            text-decoration: none;
            transition: color 0.2s;
        }

        .contact-details a:hover {
            color: var(--neon-cyan);
        }

        section {
            background: var(--panel-bg);
            border: 1px solid rgba(102, 252, 241, 0.1);
            backdrop-filter: blur(10px);
            padding: 30px;
            border-radius: var(--border-radius);
            position: relative;
            transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
        }

        section:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 20px rgba(102, 252, 241, 0.1);
            border-color: rgba(102, 252, 241, 0.3);
        }

        h2 {
            font-family: 'JetBrains Mono', monospace;
            color: var(--text-white);
            font-size: 1.1rem;
            margin-top: 0;
            margin-bottom: 20px;
            border-left: 3px solid var(--neon-cyan);
            padding-left: 15px;
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
        }

        h2::after {
            content: '';
            flex-grow: 1;
            height: 1px;
            background: rgba(102, 252, 241, 0.1);
            margin-left: 15px;
        }

        h3 {
            color: var(--neon-cyan);
            margin: 0 0 5px 0;
            font-size: 1rem;
            font-weight: 600;
        }

        .entry {
            margin-bottom: 25px;
        }

        .entry:last-child {
            margin-bottom: 0;
        }

        .meta {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.8rem;
            color: var(--neon-dim);
            margin-bottom: 8px;
            display: block;
            opacity: 0.9;
        }

        p {
            line-height: 1.6;
            font-size: 0.95rem;
            margin-top: 0;
            margin-bottom: 10px;
        }

        ul {
            list-style: none;
            padding: 0;
            margin: 0;
        }

        li {
            margin-bottom: 6px;
            padding-left: 20px;
            position: relative;
            font-size: 0.95rem;
            line-height: 1.5;
        }

        li::before {
            content: ">";
            position: absolute;
            left: 0;
            color: var(--neon-dim);
            font-family: 'JetBrains Mono', monospace;
            font-weight: bold;
        }

        .skills-container {
            display: flex;
            flex-wrap: wrap;
            gap: 10px;
        }

        .skill-tag {
            background: rgba(102, 252, 241, 0.05);
            color: var(--neon-cyan);
            padding: 6px 14px;
            border-radius: var(--border-radius);
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.85rem;
            border: 1px solid rgba(102, 252, 241, 0.2);
        }

        .skill-category {
            margin-bottom: 15px;
        }

        .category-label {
            font-family: 'JetBrains Mono', monospace;
            font-size: 0.75rem;
            color: var(--text-white);
            text-transform: uppercase;
            margin-bottom: 8px;
            display: block;
            letter-spacing: 1px;
        }

        @media (max-width: 650px) {
            header { flex-direction: column; align-items: flex-start; }
            .contact-details { text-align: left; margin-top: 20px; }
            h1 { font-size: 1.8rem; }
        }
    </style>
</head>
